{
  "name": "golem-web",
  "version": "2.0.0",
  "description": "Golem dynamic web server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "prebuild": "npm run build:css:tailwind",
    "build": "npm run build:css:purge && npm run build:js:minify && npm run build:assets",
    "build:css:tailwind": "tailwindcss -i src/input.css -o style.css --minify",
    "build:css:purge": "npx purgecss --config purgecss.config.js",
    "build:js:minify": "python3 ../../tools/build/minify-js.py",
    "build:assets": "cp -r ../../content . 2>/dev/null; cp -r ../../instructions . 2>/dev/null; python3 ../../tools/generators/generate-files-json.py"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "purgecss": "^5.0.0",
    "tailwindcss": "^3.4.19"
  },
  "dependencies": {}
}
