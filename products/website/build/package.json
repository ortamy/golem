{
  "name": "golem-web",
  "version": "2.0.0",
  "description": "Golem dynamic web server",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "prebuild": "npm run build:css:tailwind",
    "build": "npm run build:css:purge && npm run build:js:minify && npm run build:assets",
    "build:css:tailwind": "tailwindcss -i src/input.css -o style.css --minify",
    "build:css:purge": "npx purgecss --config purgecss.config.js",
    "build:js:minify": "echo 'js minify skipped'",
    "build:assets": "cp -r ../webapp ./webapp && echo 'webapp copied'"
  },
  "devDependencies": {
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.15",
    "purgecss": "^5.0.0",
    "tailwindcss": "^3.4.19"
  },
  "dependencies": {}
}