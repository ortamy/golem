          {"he": "קָרָא", "trans": "кара", "ru": "назвал"},
          {"he": "לָיְלָה", "trans": "лайла", "ru": "ночью"},
          {"he": "וַיְהִי", "trans": "ва-йеhи", "ru": "и был"},
          {"he": "עֶרֶב", "trans": "эрэв", "ru": "вечер"},
          {"he": "וַיְהִי", "trans": "ва-йеhи", "ru": "и было"},
          {"he": "בֹקֶר", "trans": "бокэр", "ru": "утро"},
          {"he": "יוֹם", "trans": "йом", "ru": "день"},
          {"he": "אֶחָד", "trans": "эхад", "ru": "один"}
        ]
