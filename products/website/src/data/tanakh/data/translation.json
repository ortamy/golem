{
  "bereshit": {
    "1": {
      "1": {
        "he": "בְּרֵאשִׁית בָּרָא אֱלֹהִים אֵת הַשָּׁמַיִם וְאֵת הָאָרֶץ",
        "translation": "В начале сотворил Всесильный небеса и землю",
        "words": [
          {"he": "בְּרֵאשִׁית", "trans": "бэрэшит", "ru": "в начале"},
          {"he": "בָּרָא", "trans": "бара", "ru": "сотворил"},
          {"he": "אֱלֹהִים", "trans": "элоhим", "ru": "Всесильный"},
          {"he": "אֵת", "trans": "эт", "ru": ""},
          {"he": "הַשָּׁמַיִם", "trans": "hа-шамаим", "ru": "небеса"},
          {"he": "וְאֵת", "trans": "вэ-эт", "ru": "и"},
          {"he": "הָאָרֶץ", "trans": "hа-арэц", "ru": "землю"}
        ]
      },
      "2": {
        "he": "וְהָאָרֶץ הָיְתָה תֹהוּ וָבֹהוּ וְחֹשֶׁךְ עַל־פְּנֵי תְהוֹם וְרוּחַ אֱלֹהִים מְרַחֶפֶת עַל־פְּנֵי הַמָּיִם",
        "translation": "А земля была пуста и хаотична, и тьма над поверхностью бездны, и дух Всесильного парил над поверхностью вод",
        "words": [
          {"he": "וְהָאָרֶץ", "trans": "вэ-hа-арэц", "ru": "а земля"},
          {"he": "הָיְתָה", "trans": "hайта", "ru": "была"},
          {"he": "תֹהוּ", "trans": "тоhу", "ru": "пуста"},
          {"he": "וָבֹהוּ", "trans": "ва-воhу", "ru": "и хаотична"},
          {"he": "וְחֹשֶׁךְ", "trans": "вэ-хошэх", "ru": "и тьма"},
          {"he": "עַל־פְּנֵי", "trans": "аль-пнэй", "ru": "над поверхностью"},
          {"he": "תְהוֹם", "trans": "тhом", "ru": "бездны"},
          {"he": "וְרוּחַ", "trans": "вэ-руах", "ru": "и дух"},
          {"he": "אֱלֹהִים", "trans": "элоhим", "ru": "Всесильного"},
          {"he": "מְרַחֶפֶת", "trans": "мэрахэфэт", "ru": "парил"},
          {"he": "עַל־פְּנֵי", "trans": "аль-пнэй", "ru": "над поверхностью"},
          {"he": "הַמָּיִם", "trans": "hа-маим", "ru": "вод"}
        ]
      },
      "3": {
        "he": "וַיֹּאמֶר אֱלֹהִים יְהִי אוֹר וַיְהִי אוֹר",
        "translation": "И сказал Всесильный: да будет свет. И стал свет",
        "words": [
          {"he": "וַיֹּאמֶר", "trans": "ва-йомэр", "ru": "и сказал"},
          {"he": "אֱלֹהִים", "trans": "элоhим", "ru": "Всесильный"},
          {"he": "יְהִי", "trans": "йеhи", "ru": "да будет"},
          {"he": "אוֹר", "trans": "ор", "ru": "свет"},
          {"he": "וַיְהִי", "trans": "ва-йеhи", "ru": "и стал"},
          {"he": "אוֹר", "trans": "ор", "ru": "свет"}
        ]
      },
      "4": {
        "he": "וַיַּרְא אֱלֹהִים אֶת־הָאוֹר כִּי־טוֹב וַיַּבְדֵּל אֱלֹהִים בֵּין הָאוֹר וּבֵין הַחֹשֶׁךְ",
        "translation": "И увидел Всесильный свет, что хорош, и отделил Всесильный между светом и между тьмою",
        "words": [
          {"he": "וַיַּרְא", "trans": "ва-йар", "ru": "и увидел"},
          {"he": "אֱלֹהִים", "trans": "элоhим", "ru": "Всесильный"},
          {"he": "אֶת־הָאוֹר", "trans": "эт-hа-ор", "ru": "свет"},
          {"he": "כִּי־טוֹב", "trans": "ки-тов", "ru": "что хорош"},
          {"he": "וַיַּבְדֵּל", "trans": "ва-йавдэль", "ru": "и отделил"},
          {"he": "אֱלֹהִים", "trans": "элоhим", "ru": "Всесильный"},
          {"he": "בֵּין", "trans": "бэйн", "ru": "между"},
          {"he": "הָאוֹר", "trans": "hа-ор", "ru": "светом"},
          {"he": "וּבֵין", "trans": "у-вэйн", "ru": "и между"},
          {"he": "הַחֹשֶׁךְ", "trans": "hа-хошэх", "ru": "тьмою"}
        ]
      },
      "5": {
        "he": "וַיִּקְרָא אֱלֹהִים לָאוֹר יוֹם וְלַחֹשֶׁךְ קָרָא לָיְלָה וַיְהִי עֶרֶב וַיְהִי בֹקֶר יוֹם אֶחָד",
        "translation": "И назвал Всесильный свет днём, а тьму назвал ночью. И был вечер, и было утро: день один",
        "words": [
